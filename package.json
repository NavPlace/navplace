{
  "name": "navplace",
  "author": "Vladimir Barbarosh <vladimir.barbarosh@gmail.com>",
  "version": "0.0.0",
  "description": "The fastest way to open your links",
  "license": "ISC",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "mocha 'lib/**/*.test.js'",
    "postinstall": "echo bin/configure-unpkg",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.navplace",
    "productName": "NavPlace",
    "afterPack": "./electron-build-scripts/afterPack.js",
    "linux": {
      "target": ["AppImage"],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@vbarbarosh/node-helpers": "3.74.0",
    "@vbarbarosh/type-helpers": "0.2.0",
    "bluebird": "^3.7.2",
    "sanitize-filename": "^1.6.3"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "mocha": "^11.7.5"
  }
}
