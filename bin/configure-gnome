#!/bin/bash

# http://www.gnu.org/software/bash/manual/bash.html#The-Set-Builtin
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o nounset -o errexit -o pipefail

script=`realpath $0`
scriptdir=`dirname $script`
scriptname=`basename $script`

cd $scriptdir/..

BLACK="\e[30m" RED="\e[31m" GREEN="\e[32m" YELLOW="\e[33m" BLUE="\e[34m"
PURPLE="\e[35m" CYAN="\e[36m" WHITE="\e[37m" RESET="\e[0m"

EXIT_MESSAGE="${RED}bin/configure-gnome failed${RESET}"
trap 'echo -e $EXIT_MESSAGE' EXIT

node << 'EOF'
const child_process = require('child_process');

main();

function main()
{
    const input = child_process.execSync('dconf read /org/gnome/settings-daemon/plugins/media-keys/custom-keybindings', {encoding: 'utf8'});
    const items = JSON.parse(input.replaceAll("'", '"')); 
    if (items.find(v => v.endsWith('navplace/'))) {
        return;
    }
    items.push('/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/navplace/');
    const tmp = child_process.spawnSync('dconf', ['write', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings', JSON.stringify(items).replaceAll('"', "'")], {encoding: 'utf8'});
    if (tmp.status) {
        console.error(tmp);
        process.exit(1);
    }
}
EOF

d=$PWD

dconf load / << EOF
[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/navplace]
binding='<Ctrl><Shift><Alt>N'
command='$d/bin/run'
name='navplace'
EOF

cat > ~/.local/share/applications/navplace.desktop << EOF
[Desktop Entry]
Encoding=UTF-8
Value=1.0
Type=Application
Name=navplace
GenericName=electron
Comment=electron
Icon=$d/ubuntu/Electron_Software_Framework_Logo.svg
Path=$d
Exec=npm start
Categories=Utility;
StartupWMClass=@vbarbarosh/navplace
EOF

EXIT_MESSAGE="${GREEN}bin/configure-gnome succeeded${RESET}"
